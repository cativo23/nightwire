{
  "name": "@cativo23/nightwire",
  "version": "1.0.14",
  "description": "CLI installer for the Nightwire cyberpunk UI design system",
  "main": "dist/index.js",
  "bin": {
    "nightwire": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "nightwire.css",
    "tailwind.preset.js",
    "DESIGN.md",
    "skill/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cativo23/nightwire.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "nightwire",
    "design-system",
    "cyberpunk",
    "cli",
    "dark-mode"
  ],
  "author": "cativo23",
  "license": "MIT",
  "dependencies": {
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.0"
  }
}
